# Copy this file to `.env` (gitignored) and fill in your keys. Do NOT paste keys into chat.
# Gemini: free key from Google AI Studio -> https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Google Translate: Google Cloud Console -> enable "Cloud Translation API" -> create an API key
# (requires a billing-enabled GCP project; ~$1-2 for the 846-sentence test set)
GOOGLE_TRANSLATE_API_KEY=

# Hugging Face token (read scope) — required for gated QE model Unbabel/wmt22-cometkiwi-da
HF_TOKEN=
