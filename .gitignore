# --- Data: license-sensitive ----------------------------------------------
# WikiHow source is CC BY-NC-SA 3.0; the corpus is released by *rehydration*
# (Myanmar text + source URLs + the build script), never by mirroring the
# English WikiHow text. So the parallel files stay out of the public repo.
data/raw/
data/processed/*.jsonl
# A 20-row teaser (data/sample/) and the aggregate stats JSONs ARE committed.
# Human-rating sheets embed English source text -> keep local (rehydration policy).
experiments/results/ratings*.csv

# --- Models / checkpoints / runs -------------------------------------------
ckpt/
checkpoints/
*.pt
*.bin
*.safetensors
runs/
wandb/
mlruns/

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env
.ipynb_checkpoints/

# --- Internal scratch / session notes (not part of the artifact) -----------
SESSION_STATE_*.md
_archive/

# --- AI tool artifacts (never commit) --------------------------------------
.sixth/
.claude/
.cursor/
.aider*
.codeium/

# --- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- LaTeX build artifacts (rebuildable from main.tex + references.bib) -----
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
paper/main.pdf

# MetricX input JSONLs contain English source text -> keep off GitHub (rehydration policy)
experiments/results/metricx_inputs/

# Kaggle kernel logs (may echo source text; not research artifacts)
experiments/results/*.log

# reranking intermediates (large; Burmese candidates + QE scores, no English source)
experiments/results/nbest/

# Rater web app (separate Vercel project; its data/tasks.json bundles English source -> rehydration policy)
rating-app/

# MCP server config -- may hold API tokens, NEVER commit
.mcp.json

# Compiled PDFs and stray LaTeX build artifacts (keep .tex/.bib/.sty/.bst sources only)
*.pdf
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.fls
paper/*.fdb_latexmk
paper/_*.log
paper/build.log
paper/flagship/
